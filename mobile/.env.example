# Dangg mobile — environment variables template.
# Copy to `.env` (never commit) and fill in. `react-native-config` reads
# this at build time and exposes typed values via `src/core/config/env.ts`.

# --- Runtime mode --------------------------------------------------------
APP_ENV=development                # development | staging | production
DEV_MODE=true                      # true bypasses real OTPs during dev

# --- Supabase ------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Cloudinary (public values only — secret stays server-side) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# --- Razorpay (public key id only — secret stays server-side) ------------
RAZORPAY_KEY_ID=

# --- FCM (Firebase is OPT-IN — see ENABLE_FIREBASE) ----------------------
ENABLE_FIREBASE=false
FCM_PROJECT_ID=
